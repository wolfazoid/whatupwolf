---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('video'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Video — whatupwolf">
  <h1 class="text-2xl font-semibold tracking-tight">Video</h1>
  <p class="mt-2 text-[var(--color-muted)]">Talks, demos, and screencasts.</p>
  <div class="mt-6">
    {entries.length === 0 && <p class="chrome py-4">nothing published yet.</p>}
    {entries.map((e) => (
      <div class="border-b border-[var(--color-line)] py-4">
        <div class="chrome">{e.data.date.toISOString().slice(0, 10)}</div>
        <h3 class="mt-1 font-semibold tracking-tight">
          <a href={e.data.embed} class="hover:text-[var(--color-accent)]">{e.data.title} ↗</a>
        </h3>
        <p class="mt-1 text-[var(--color-muted)] text-sm leading-relaxed">{e.data.summary}</p>
      </div>
    ))}
  </div>
</Base>
