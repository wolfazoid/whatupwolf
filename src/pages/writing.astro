---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('writing'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Writing — whatupwolf">
  <h1 class="text-2xl font-semibold tracking-tight">Writing</h1>
  <p class="mt-2 text-[var(--color-muted)]">Human-authored essays and posts.</p>
  <div class="mt-6">
    {entries.length === 0 && <p class="chrome py-4">nothing published yet.</p>}
    {entries.map((e) => (
      <div class="border-b border-[var(--color-line)] py-4">
        <div class="chrome">{e.data.date.toISOString().slice(0, 10)}</div>
        <h3 class="mt-1 font-semibold tracking-tight">{e.data.title}</h3>
        <p class="mt-1 text-[var(--color-muted)] text-sm leading-relaxed">{e.data.summary}</p>
      </div>
    ))}
  </div>
</Base>
