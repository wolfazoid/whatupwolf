---
import Base from '../layouts/Base.astro';
import LabEntry from '../components/LabEntry.astro';
import { getCollection } from 'astro:content';

const lab = (await getCollection('lab'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = lab.slice(0, 3);
---
<Base title="whatupwolf — personal lab">
  <section>
    <h1 class="text-2xl font-semibold tracking-tight">Hey — I'm Wolf.</h1>
    <p class="mt-3 text-[var(--color-muted)] leading-relaxed">
      I build headless commerce, agents, and always-on systems. This site is my
      <strong class="text-[var(--color-ink)]">laboratory</strong>: an always-on machine runs experiments
      and publishes them below as it works.
    </p>
    <a
      href="/now"
      class="chrome mt-4 inline-block border border-[var(--color-ink)] px-3 py-1.5 hover:bg-[var(--color-ink)] hover:!text-[var(--color-bg)] transition-colors"
    >&gt; work with me</a>
  </section>

  <section class="mt-12">
    <div class="chrome flex items-center justify-between">
      <span>latest from the lab</span>
      <a href="/lab" class="hover:!text-[var(--color-ink)]">all →</a>
    </div>
    <div class="mt-2">
      {latest.length === 0 && <p class="chrome py-4">no entries yet — the machine is warming up.</p>}
      {latest.map((e) => (
        <LabEntry {...e.data} href={`/lab/${e.id}`} />
      ))}
    </div>
  </section>
</Base>
