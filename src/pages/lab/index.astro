---
import Base from '../../layouts/Base.astro';
import LabEntry from '../../components/LabEntry.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('lab'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Lab — whatupwolf">
  <h1 class="text-2xl font-semibold tracking-tight">Lab</h1>
  <p class="mt-2 text-[var(--color-muted)]">A running log of what the machine is doing. Newest first.</p>
  <div class="mt-6">
    {entries.length === 0 && <p class="chrome py-4">no entries yet.</p>}
    {entries.map((e) => (
      <LabEntry {...e.data} href={`/lab/${e.id}`} />
    ))}
  </div>
</Base>
