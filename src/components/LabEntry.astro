---
import LevelText from './LevelText.astro';
import type { LevelText as LevelVariants } from '../lib/tech-level';

type Variants = Omit<LevelVariants, 'technical'>;

interface Props {
  title: string;
  titleLevels?: Variants;
  date: Date;
  type: string;
  status: string;
  tags: string[];
  live: boolean;
  summary: string;
  summaryLevels?: Variants;
  href?: string;
  tool?: string;
}
const {
  title,
  titleLevels,
  date,
  type,
  status,
  tags,
  live,
  summary,
  summaryLevels,
  href,
  tool,
} = Astro.props;
const ts = date.toISOString().slice(0, 16).replace('T', ' ');
const Tag = href ? 'a' : 'div';
---
<Tag href={href} class="block border-b border-[var(--color-line)] py-4 group">
  <div class="chrome flex items-center gap-2">
    {live && <span class="live-dot" title="live — just updated"></span>}
    <span>{ts}</span>
    <span class="text-[var(--color-accent)]">[{type}]</span>
    <span>status: {status}</span>
  </div>
  <h3 class="mt-1 font-semibold tracking-tight group-hover:text-[var(--color-accent)] transition-colors">
    <LevelText technical={title} {...titleLevels} />
  </h3>
  <p class="mt-1 text-[var(--color-muted)] text-sm leading-relaxed">
    <LevelText technical={summary} {...summaryLevels} />
  </p>
  {tags.length > 0 && (
    <div class="chrome mt-2 flex flex-wrap gap-2" data-variant="technical aware">
      {tags.map((t) => <span>#{t}</span>)}
    </div>
  )}
  {tool && (
    href
      /* The whole card is already an <a>, so signal the tool with a marker
         rather than nesting a second anchor — the entry page carries the link. */
      ? <span class="chrome mt-2 inline-block !text-[var(--color-accent)] font-semibold">try it →</span>
      : <a href={tool} class="chrome mt-2 inline-block !text-[var(--color-accent)] font-semibold hover:underline underline-offset-4">Try it →</a>
  )}
</Tag>
